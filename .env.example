# App
NODE_ENV=development
PORT=3000
APP_NAME=BlinkCampusAPI
API_VERSION=v1

# Database
DATABASE_URL="postgresql://blink_admin:Blink@2025Secure!@localhost:5432/blink_campus_db?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=super-secret-access-key-change-in-production-2025
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production-2025
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS S3 / MinIO (dev: points to local MinIO container)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_minio_or_aws_key
AWS_SECRET_ACCESS_KEY=your_minio_or_aws_secret
AWS_S3_BUCKET_NAME=blink-campus-files
AWS_S3_BUCKET_REGION=us-east-1
AWS_ENDPOINT=http://localhost:9000

# MinIO container credentials (must match docker-compose)
MINIO_ROOT_USER=your_minio_or_aws_key
MINIO_ROOT_PASSWORD=your_minio_or_aws_secret

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=300

# Email (SMTP — MailHog for dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@blinkcampus.com

# Admin seed
SUPER_ADMIN_EMAIL=admin@blinkcampus.com
SUPER_ADMIN_PASSWORD=Admin@2025
