# App
NODE_ENV=development
PORT=3000
APP_NAME=BlinkCampusAPI
API_VERSION=v1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# PostgreSQL Configuration
POSTGRES_USER=blink_user
POSTGRES_PASSWORD=blink_password
POSTGRES_DB=blink_db
POSTGRES_PORT=5437

# Full connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ireme
5
# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=super-secret-access-key-change-in-production-2025
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production-2025
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS S3 / MinIO (dev: points to local MinIO container)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=blink_minio_key
AWS_SECRET_ACCESS_KEY=blink_minio_secret_2025
AWS_S3_BUCKET_NAME=blink-campus-files
AWS_S3_BUCKET_REGION=us-east-1
AWS_ENDPOINT=http://localhost:9000

# MinIO container credentials (must match docker-compose)
MINIO_ROOT_USER=blink_minio_key
MINIO_ROOT_PASSWORD=blink_minio_secret_2025

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=300

# Email (SMTP — MailHog catches everything in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@blinkcampus.com

# Admin seed
SUPER_ADMIN_EMAIL=admin@blinkcampus.com
SUPER_ADMIN_PASSWORD=Admin@2025
